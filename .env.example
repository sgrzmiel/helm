# Helm - example environment file. Copy to .env and fill in.

# Required: Anthropic key for all LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Required: Atlassian credentials for Jira + Confluence (same site/token)
ATLASSIAN_DOMAIN=example.atlassian.net
ATLASSIAN_EMAIL=you@company.com
ATLASSIAN_API_TOKEN=...

# Required if your network MITMs HTTPS (corporate proxy with self-signed CA).
# Set to false to skip cert verification on outbound httpx calls.
JIRA_VERIFY_SSL=true

# Required: password gate for the app. Anyone who can reach the local port
# can read the dashboard (read-only) but needs this password to make changes.
# Leave blank to run the app in open mode (single-user dev only).
APP_PASSWORD=change-me

# Optional - only needed if you paste a Figma URL in the UI.
# Generate at https://www.figma.com/developers/api#access-tokens
FIGMA_API_TOKEN=

# Optional - Google Drive OAuth (Docs + Slides fetching for linked docs).
# Set up via Google Cloud Console, paste from Settings tab.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
